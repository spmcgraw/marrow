# Database
DATABASE_URL=postgresql://marrow:marrow@localhost:5433/marrow

# Security
SECRET_KEY=changeme

# Storage
# Relative paths resolve from the api/ directory; absolute paths also work.
STORAGE_PATH=./storage

# API key authentication (optional — omit to allow anonymous access in dev)
# API_KEY=

# CORS (comma-separated origins; defaults to http://localhost:3000)
# CORS_ORIGINS=http://localhost:3000

# OIDC Authentication (optional — omit OIDC_ISSUER to disable)
# When configured, users must sign in via the OIDC provider.
# API key auth is preserved as a fallback for CLI and scripts.
# OIDC_ISSUER=https://accounts.google.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:8000/api/auth/callback
# FRONTEND_URL=http://localhost:3000
# COOKIE_DOMAIN=localhost
